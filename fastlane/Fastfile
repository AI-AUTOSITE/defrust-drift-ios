default_platform(:ios)

APP_IDENTIFIER = "com.defrust.drift"
TEAM_ID = "B8ZA589WPN"

platform :ios do
  # ────────────────────────────────────────────────────────────────────
  # LOCAL bootstrap / renewal — run this ON YOUR MAC (not CI):
  #   bundle exec fastlane certificates
  # Creates the App Store distribution certificate + provisioning profile
  # and stores them (encrypted) in the drift-certificates repo. Re-run when
  # the certificate expires (~1 year). You'll be asked for the match passphrase.
  # ────────────────────────────────────────────────────────────────────
  desc "Create/refresh signing certs & profiles (run locally)"
  lane :certificates do
    api_key = app_store_connect_api_key(
      key_id: "C2BW8953N7",
      issuer_id: "06b4bf48-5572-4aaf-b6db-8f3fed9b37d9",
      key_filepath: File.expand_path("~/Documents/.p8/AuthKey_C2BW8953N7.p8"),
      duration: 500,
      in_house: false
    )

    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      readonly: false # allow creating & storing the cert + profile
    )
  end

  # ── Unit tests (unchanged) ──────────────────────────────────────────
  desc "Run unit tests via the DriftUnit test plan (StoreKit suite skipped, as on CI)"
  lane :test do
    run_tests(
      project: "Drift.xcodeproj",
      scheme: "Drift",
      testplan: "DriftUnit",
      skip_testing: ["DriftTests/DriftStorePurchaseTests"],
      code_coverage: true,
      result_bundle: true
    )
  end

  # ────────────────────────────────────────────────────────────────────
  # CI — build & upload to TestFlight (runs on GitHub Actions).
  # Installs the cert+profile that `certificates` stored, signs manually,
  # archives, and uploads. No -authenticationKeyPath / cloud signing.
  # ────────────────────────────────────────────────────────────────────
  desc "Build and upload to TestFlight (internal testers only)"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"], # base64-encoded .p8
      is_key_content_base64: true,
      duration: 500,
      in_house: false
    )

    # Pull the App Store cert + private key + profile from the certs repo.
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      readonly: true
    )

    # Force manual signing for the archive and use the profile match installed.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Drift.xcodeproj",
      team_id: TEAM_ID,
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING][APP_IDENTIFIER]
    )

    build_app(
      project: "Drift.xcodeproj",
      scheme: "Drift",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{ENV['GITHUB_RUN_NUMBER'] || '1'}"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["BETA_CHANGELOG"] || "Internal CI build",
      distribute_external: false,
      notify_external_testers: false
    )
  end
end
