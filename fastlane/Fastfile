default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Run unit tests via the DriftUnit test plan (StoreKit suite skipped, as on CI)"
  lane :test do
    run_tests(
      project: "Drift.xcodeproj",
      scheme: "Drift",
      testplan: "DriftUnit",
      skip_testing: ["DriftTests/DriftStorePurchaseTests"],
      code_coverage: true,
      result_bundle: true
    )
  end

  desc "Build and upload a build to TestFlight (internal testers only)"
  lane :beta do
    require "base64"
    require "fileutils"

    key_id    = ENV["APP_STORE_CONNECT_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    build_no  = ENV["GITHUB_RUN_NUMBER"] || "1"

    # xcodebuild's -authenticationKeyPath REQUIRES the file to be named
    # AuthKey_<KeyID>.p8 and placed in the standard private_keys dir. Any other
    # name is rejected with "JWT keyPathInvalid" — which is what we kept hitting.
    key_dir  = File.join(Dir.home, ".appstoreconnect", "private_keys")
    FileUtils.mkdir_p(key_dir)
    key_path = File.join(key_dir, "AuthKey_#{key_id}.p8")
    File.binwrite(key_path, Base64.decode64(ENV["APP_STORE_CONNECT_KEY_CONTENT"]))

    # Key hash for the upload step. (upload_to_testflight accepts api_key;
    # gym/build_app does NOT — that option doesn't exist there.)
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"], # base64-encoded .p8
      is_key_content_base64: true,
      duration: 1200,
      in_house: false
    )

    # Authenticate xcodebuild via the auth-key flags (now pointing at the
    # correctly named file) and set the build number via the build setting.
    xcargs = [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath", key_path,
      "-authenticationKeyID", key_id,
      "-authenticationKeyIssuerID", issuer_id,
      "CURRENT_PROJECT_VERSION=#{build_no}"
    ].join(" ")

    build_app(
      project: "Drift.xcodeproj",
      scheme: "Drift",
      configuration: "Release",
      export_method: "app-store",
      xcargs: xcargs,
      export_options: {
        signingStyle: "automatic",
        manageAppVersionAndBuildNumber: false
      },
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["BETA_CHANGELOG"] || "Internal CI build",
      distribute_external: false,
      notify_external_testers: false
    )
  end
end
