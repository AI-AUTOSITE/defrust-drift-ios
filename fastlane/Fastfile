default_platform(:ios)

APP_IDENTIFIER = "com.defrust.drift"
TEAM_ID = "B8ZA589WPN"

platform :ios do
  # ────────────────────────────────────────────────────────────────────
  # LOCAL bootstrap / renewal — run this ON YOUR MAC (not CI):
  #   bundle exec fastlane certificates
  # ────────────────────────────────────────────────────────────────────
  desc "Create/refresh signing certs & profiles (run locally)"
  lane :certificates do
    api_key = app_store_connect_api_key(
      key_id: "C2BW8953N7",
      issuer_id: "06b4bf48-5572-4aaf-b6db-8f3fed9b37d9",
      key_filepath: File.expand_path("~/Documents/.p8/AuthKey_C2BW8953N7.p8"),
      duration: 500,
      in_house: false
    )

    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      readonly: false
    )
  end

  desc "Run unit tests via the DriftUnit test plan (StoreKit suite skipped, as on CI)"
  lane :test do
    run_tests(
      project: "Drift.xcodeproj",
      scheme: "Drift",
      testplan: "DriftUnit",
      skip_testing: ["DriftTests/DriftStorePurchaseTests"],
      code_coverage: true,
      result_bundle: true
    )
  end

  # ────────────────────────────────────────────────────────────────────
  # CI — build & upload to TestFlight (runs on GitHub Actions).
  # ────────────────────────────────────────────────────────────────────
  desc "Build and upload to TestFlight (internal testers only)"
  lane :beta do
    require "base64"
    require "fileutils"

    setup_ci

    key_id    = ENV["APP_STORE_CONNECT_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]

    # Decode the base64 .p8 ONCE, to the standard location altool reads from.
    # This avoids the fastlane/altool double-decode bug that makes altool fail
    # with "Failed to generate JWT token ... 259 (not in correct format)".
    key_dir  = File.join(Dir.home, ".appstoreconnect", "private_keys")
    FileUtils.mkdir_p(key_dir)
    key_path = File.join(key_dir, "AuthKey_#{key_id}.p8")
    File.binwrite(key_path, Base64.decode64(ENV["APP_STORE_CONNECT_KEY_CONTENT"]))

    # For match: build the key from the file we just wrote (already-decoded),
    # so nothing is base64-decoded a second time.
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
      duration: 500,
      in_house: false
    )

    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      readonly: true
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Drift.xcodeproj",
      team_id: TEAM_ID,
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING][APP_IDENTIFIER]
    )

    build_app(
      project: "Drift.xcodeproj",
      scheme: "Drift",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{ENV['GITHUB_RUN_NUMBER'] || '1'}"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["BETA_CHANGELOG"] || "Internal CI build",
      distribute_external: false,
      notify_external_testers: false
    )
  end
end
